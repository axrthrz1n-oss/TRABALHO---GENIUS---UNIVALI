using namespace std;

//  VARIAVEIS GLOBAIS DE DIFICULDADE - 
int dificuldade       = 1;
int tamanhoSequencia  = 10;
int variacaoDigitos   = 3;
int digitosPorRodada  = 2;
int tempoEntreDigitos = 5;

//  FUNCOES AUXILIARES -
void limparTela() {
    #ifdef _WIN32
        system("cls");
    #else
        system("clear");
    #endif
}

void esperar(int segundos) {
    #ifdef _WIN32
        Sleep(segundos * 1000);
    #else
        sleep(segundos);
    #endif
}

void separador() {
    cout << "========================================" << endl;
}

